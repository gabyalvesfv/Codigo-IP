                print(f"{nome_amigo}, você já votou neste anime! Escolha um outro anime para ocupar a sua {k}º posição!")
            anime = input()
            anime = anime.title()

        animes_votados.append(anime)

        if k == 1 :
            pontuacao.append(anime)
            pontuacao.append(anime)
            pontuacao.append(anime)
        elif k == 2 :
            pontuacao.append(anime)
            pontuacao.append(anime)
        elif k == 3 :
            pontuacao.append(anime)
        print(f"{nome_amigo} colocou {anime} em {k}º lugar do seu ranking!")

vencedor = ""
