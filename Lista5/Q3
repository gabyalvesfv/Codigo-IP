            lista_polinomio[i] = ['-1', '1']
        elif lista_polinomio[i] == 'x' :
            lista_polinomio[i] = ['1', '1']
        else :
            lista_polinomio[i] = [lista_polinomio[i].replace('x', ''), '1']
