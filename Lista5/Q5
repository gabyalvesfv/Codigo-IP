def busca_palavra(matriz, tam_matriz, palavra, direcoes, a, b, idx) :
    # Caso base (quando a palavra for toda encontrada)
    if idx == len(palavra) :
        return True
    
    # Caso o 'a' não estejas nos limites da matriz
    if a < 0 or a >= tam_matriz:
        return False
    # Caso o 'b' não estejas nos limites da matriz
    if b < 0 or b >= tam_matriz:
        return False
    # Caso a letra da matriz seja diferente da letra da palavra 
    if matriz[a][b] != palavra[idx]:
        return False
    
    #  Busca a palavra nas 8 direções possiveis se as direções a e b forem possiveis 
    for direcao_a, direcao_b in direcoes :
        if busca_palavra(matriz, tam_matriz, palavra, direcoes, a + direcao_a, b + direcao_b, idx + 1) :
            return True
    
    # Caso a palavra não seja encontrada
    return False

def definicao_lugar(matriz, tam_matriz) :
