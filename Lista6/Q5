# Cálculo da pontuação 
def calcula_pontuacao(palavra_digitada, palavras_portugues) :
    pontuacao = 0
    # Compara a ordenada da palavra digitada com as demais palavras em português no dicionário
    for i in range(min(len(palavra_digitada), len(palavras_portugues))) :
        pontuacao += ord(palavra_digitada[i]) - ord(palavras_portugues[i])
    return pontuacao

