        # Dicionário de suguestões com a palavra em português e sua respectiva pontuação
        sugestoes[palavra] = pontuacao

    # Ordena a lista de suguestões 
    sugestoes_ordenadas = sorted(sugestoes.keys(), key=lambda x: sugestoes[x])
    
    return sugestoes_ordenadas[:4]

